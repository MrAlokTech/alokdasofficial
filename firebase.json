{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      "**/.git/**",
      "**/node_modules/**",
      "resume.html"
    ],
    "cleanUrls": true,
    "trailingSlash": false,
    "rewrites": [
      { "source": "/resume",                    "destination": "/resume/index.html" },
      { "source": "/projects/phytochemical",    "destination": "/projects/phytochemical/index.html" },
      { "source": "/projects/alomole",          "destination": "/projects/alomole/index.html" },
      { "source": "/projects/mileage-tracker",  "destination": "/projects/mileage-tracker/index.html" },
      { "source": "/projects/portfolio",        "destination": "/projects/portfolio/index.html" },
      { "source": "/projects",                  "destination": "/index.html" }
    ],
    "headers": [
      {
        "source": "**",
        "headers": [
          { "key": "X-Content-Type-Options",  "value": "nosniff" },
          { "key": "X-Frame-Options",         "value": "SAMEORIGIN" },
          { "key": "Referrer-Policy",         "value": "strict-origin-when-cross-origin" }
        ]
      },
      {
        "source": "**/*.@(js|css)",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
        ]
      },
      {
        "source": "**/*.html",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
        ]
      }
    ]
  }
}
